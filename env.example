# ── LLM ─────────────────────────────────────────────
API_KEY=your_api_key_here

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ── LLM Settings ─────────────────────────────────────
TEMPERATURE=0.3

# ── Retrieval ────────────────────────────────────────
TOP_K=10
STRATEGY=semantic
BM25_W=0.4
FAISS_W=0.6

# ── File Upload ──────────────────────────────────────
MAX_FILE_SIZE=10485760

# ── Redis ────────────────────────────────────────────
REDIS=redis://localhost:6379/0

# ── RAG Quality Control ──────────────────────────────
MIN_RELEVANT_DOCS=2
RELEVANCE_THRESHOLD=0.01
CONFIDENCE=0.3
MAX_RETRY=2
CONFIDENCE_THRESHOLD=0.7
